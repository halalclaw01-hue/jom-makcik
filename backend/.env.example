NODE_ENV=development
PORT=4000
DATABASE_PATH=./data/jom-makcik.sqlite
JWT_SECRET=replace-with-a-long-random-local-secret
JWT_EXPIRES_IN=8h
# Comma-separated list of allowed origins for CORS.
# Leave empty in development to allow localhost:5173 and localhost:3000.
# In production, set to your admin-web URL.
# Example: CORS_ORIGINS=https://admin.jommakcik.com,http://localhost:5173
CORS_ORIGINS=
